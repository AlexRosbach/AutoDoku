# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

