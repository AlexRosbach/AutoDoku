build/
dist/
*.spec.bak

# ── Egg / packaging ──────────────────────────────────────────────────────────
*.egg-info/
*.egg
dist/
.eggs/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
autodoku.log

